# 飞书开放平台应用凭据（FEISHU_APP_KEY 也可替代 FEISHU_APP_ID）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxx

# NextAuth 会话加密密钥。首次生成后必须保持稳定，否则旧 Cookie 会报 JWEDecryptionFailed
AUTH_SECRET=replace-with-a-stable-random-string-at-least-32-bytes

# 只用于签发和验证 MCP JWT；轮换它会立即使已生成的 MCP Token 失效
MCP_JWT_SECRET=replace-with-a-separate-random-string-at-least-32-bytes

# 飞书用户 open_id（ou_xxx），逗号分隔；管理员自动拥有登录和全部写入权限
FEISHU_ALLOWED_OPEN_IDS=ou_reader
FEISHU_ADMIN_OPEN_IDS=ou_admin
